<?xml version="1.0" encoding="UTF-8"?>
<database xmlns="http://stano.com/database"
          xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
          xsi:schemaLocation="http://stano.com/database https://raw.githubusercontent.com/jstano/java-schema/refs/heads/main/schema-model/src/resources/schema.xsd">
  <table name="person">
    <columns>
      <column name="id" type="uuid" required="true"/>
      <column name="name" type="text" required="true"/>
      <column name="birth_date" type="date" required="true"/>
      <column name="address" type="text"/>
      <column name="created_at" type="timestamptz" required="true"/>
      <column name="updated_at" type="timestamptz" required="true"/>
      <column name="version" type="int" required="true"/>
    </columns>
    <keys>
      <primary>
        <column name="id"/>
      </primary>
    </keys>
  </table>
</database>
